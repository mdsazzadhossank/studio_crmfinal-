# Database Configuration
DB_HOST=localhost
DB_NAME=studio_pro_crm
DB_USER=root
DB_PASS=
DB_PORT=3306
DB_CHARSET=utf8mb4

# App Configuration
APP_URL=http://localhost
APP_DEBUG=true
APP_SECRET=change_this_to_a_random_64_char_string_for_session_security

# CORS - Frontend URL (comma separated for multiple origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload limits
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=uploads/

# Session
SESSION_LIFETIME=86400
